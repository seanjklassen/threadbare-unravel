<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Unravel Installer</title>
    <options customize="always" require-scripts="true"/>
    <welcome file="welcome.html"/>
    <license file="license.html"/>
    <conclusion file="conclusion.html"/>

    <choices-outline>
        <line choice="choice_vst3"/>
        <line choice="choice_au"/>
    </choices-outline>

    <choice id="choice_vst3" visible="true" enabled="true" selected="true" title="VST3">
        <pkg-ref id="com.threadbare.unravel.vst3"/>
    </choice>

    <choice id="choice_au" visible="true" enabled="true" selected="true" title="Audio Unit">
        <pkg-ref id="com.threadbare.unravel.component"/>
    </choice>

    <pkg-ref id="com.threadbare.unravel.vst3">unravel-vst3.pkg</pkg-ref>
    <pkg-ref id="com.threadbare.unravel.component">unravel-au.pkg</pkg-ref>
</installer-gui-script>
